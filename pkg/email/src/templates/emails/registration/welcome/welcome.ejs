<!DOCTYPE html>
<html>

<head>
  <title><%= brandName %> - Welcome</title>
</head>

<body style="margin: 0;padding: 0;background: <%= primaryColor %>;">
  <div style="max-width:600px;margin: 0 auto;background: #ffffff;">
    <table style="font-family: arial, sans-serif;
                  border-collapse: collapse;
                  width: 100% !important;
                  font-size: 16px;">
      <tr>
        <td style="background: <%= primaryColor %>; padding: 20px; text-align: center;">
          <img src="cid:logo" style="height: 50px;" alt="<%= brandName %>" />
        </td>
      </tr>
      <tr>
        <td style="padding:20px 40px; color: <%= primaryColor %>; text-align: center;font-size: 18px;line-height: 25px;">
          <strong>
            <%= tagline %><br />
            We don't add hidden fees and we put technology<br />
            at the heart of everything we do.
          </strong>
        </td>
      </tr>
      <td style="padding:20px 40px; color: <%= primaryColor %>; text-align: center;font-size: 18px;line-height: 25px;">
        <strong>
          Please read the terms and conditions attached to this email.
        </strong>
      </td>
      <tr>
        <td style="padding:0px 10px 10px 10px; color: <%= accentColor %>; text-align: center;font-size: 20px;line-height: 25px;">
          <strong>
            Tips to get started
          </strong>
        </td>
      </tr>
      <tr>
        <td style="padding:0px 10px 20px 10px; color: <%= accentColor %>; font-size: 20px;line-height:18px;">
          <table style="font-family: arial, sans-serif;
                        border-collapse: collapse;
                        width: 100% !important;
                        font-size: 16px;">
            <tr>
              <td width="25%" style="text-align: right; padding:0px 20px 10px 0;">
                <img src="cid:icon-1" style="max-width:100%;" width="60" alt="" />
              </td>
              <td valign="top" width="75%" style="padding:0px 50px 10px 0;">
                <p style="font-size: 16px;color:<%= primaryColor %>;">
                  <strong>
                    Verify your identity
                  </strong>
                </p>
                <p style="font-size: 14px;color:<%= primaryColor %>;">
                  Verifying your identity with us only takes a few minutes
                  and, because we believe in using technology whenever
                  possible, can be done directly from your phone.
                  Send us a picture of a valid government-issued photo ID
                  and a picture of your face,
                   or <a href="mailto:<%= contactEmail %>" style="text-decoration:underline; color: <%= primaryColor %>;">alternatively arrange a video call with us here</a>.
                </p>
              </td>
            </tr>
            <tr>
              <td width="25%" style="text-align: right; padding:20px 20px 10px 0;">
                <img src="cid:icon-1" style="max-width:100%;" width="60" alt="" />
              </td>
              <td valign="top" width="75%" style="padding:20px 50px 10px 0;">
                <p style="font-size: 16px;color:<%= primaryColor %>;">
                  <strong>
                    Top up money
                  </strong>
                </p>
                <p style="font-size: 14px;color:<%= primaryColor %>;">
                  Tap the '+' icon in the top right corner of your currency
                  balance page to top up your account by bank transfer.
                </p>
              </td>
            </tr>
            <tr>
              <td width="25%" style="text-align: right; padding:20px 20px 10px 0;">
                <img src="cid:icon-1" style="max-width:100%;" width="60" alt="" />
              </td>
              <td valign="top" width="75%" style="padding:20px 50px 10px 0;">
                <p style="font-size: 16px;color:<%= primaryColor %>;">
                  <strong>
                    Send and receive currencies
                  </strong>
                </p>
                <p style="font-size: 14px;color:<%= primaryColor %>;">
                  Send money around the world, and avoid the banks'
                  unfair exchange rates. Receive money into your local
                  and international named accounts.
                </p>
              </td>
            </tr>
            <tr>
              <td width="25%" style="text-align: right; padding:20px 20px 10px 0;">
                <img src="cid:icon-1" style="max-width:100%;" width="60" alt="" />
              </td>
              <td valign="top" width="75%" style="padding:20px 50px 10px 0;">
                <p style="font-size: 16px;color:<%= primaryColor %>;">
                  <strong>
                    Hold and convert all major currencies
                  </strong>
                </p>
                <p style="font-size: 14px;color:<%= primaryColor %>;">
                  Hold or convert multiple currencies at real FX rates in
                  seconds with low, transparent fees.
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
      <tr>
        <td style="padding:0px 10px 20px 10px; color: <%= accentColor %>; text-align: center;font-size: 20px;line-height: 25px;">
          <strong>
            Your questions answered
          </strong>
        </td>
      </tr>
      <tr>
        <td style="padding:0px 10px 20px 10px; color: <%= primaryColor %>; text-align: center;font-size: 20px;line-height: 25px;">
          <strong>
            Tips to get started with <%= brandName %>
          </strong>
        </td>
      </tr>
      <tr>
        <td style="text-align: center;">
          <a href="<%= helpUrl %>">
            <img src="cid:help-center" style="max-width:100%;" width="118" alt="Help" />
          </a>
        </td>
      </tr>
      <tr>
        <td
          style="padding-top:100px;padding-bottom:40px;padding-left:5%;padding-right:5%;text-align: center;font-size: 12px;color: <%= primaryColor %>;">
          <%= disclaimer %><br />
          <%= legalAddress %><br />
          Telephone calls may be recorded.<br />
          <%= contactPhone %>
        </td>
      </tr>
    </table>
  </div>
</body>

</html>
