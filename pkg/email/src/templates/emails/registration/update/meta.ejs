<!DOCTYPE html>
<html>

<head>
  <title><%= brandName %> - Update Metadata Request</title>
</head>

<body style="margin: 0;padding: 0;background: #00569e;">
  <div style="max-width:600px;margin: 0 auto;background: #ffffff;">
    <table style="font-family: arial, sans-serif;
                  border-collapse: collapse;
                  width: 100% !important;
                  font-size: 16px;">
      <tr>
        <td>
          <img src="cid:hero" style="width:100%;" alt="<%= brandName %>" />
        </td>
      </tr>
      <tr>
        <td style="padding:20px 40px; color: #00569e; text-align: center;font-size: 18px;line-height: 25px;">
          <strong>
            The client (<%= from %>) requested to update his metadata.
          </strong>
        </td>
      </tr>
      <% for (var i = 0; i<data.length; i++) { %>
        <tr>
          <td style="padding: 10px 80px 10px 80px; color: #f49c0e; font-weight: 700;"><%= data[i].field %> : <%= data[i].value %></td>
        </tr>
      <% } %>
      <tr>
        <td
          style="padding-top:100px;padding-bottom:40px;padding-left:5%;padding-right:5%;text-align: center;font-size: 12px;color: <%= primaryColor %>;">
          <%= disclaimer %><br />
          <%= legalAddress %><br />
          Telephone calls may be recorded.<br />
          <%= contactPhone %>
        </td>
      </tr>
    </table>
  </div>
</body>

</html>