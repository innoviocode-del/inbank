<!DOCTYPE html>
<html>

<body style="margin: 0;padding: 0;background: #00569e;">
  <section style="max-width:600px;margin: 0 auto;background: #ffffff;">
    <table style="font-family: arial, sans-serif;
                  border-collapse: collapse;
                  width: 100% !important;
                  font-size: 16px;">
      <tr>
        <td>
          <img src="cid:hero" style="width:100%;" alt="<%= brandName %>" />
        </td>
      </tr>
      <tr>
        <td style="padding:20px 40px; color: #00569e; text-align: center;font-size: 18px;line-height: 25px;">
          <strong>
            You requested a password reset.<br />
            <br />
            Click the link below to set a new password:
          </strong>
        </td>
      </tr>

      <tr>
        <td style="text-align: center; padding: 20px 40px;">
          <a href="<%=resetUrl%>" style="display:inline-block;padding:12px 32px;background:#00569e;color:#ffffff;text-decoration:none;border-radius:4px;font-weight:bold;">
            Reset Password
          </a>
        </td>
      </tr>
      <tr>
        <td style="padding:10px 40px; color: #666666; text-align: center;font-size: 13px;line-height: 20px;">
          This link expires in 1 hour. If you did not request this, please ignore this email.
        </td>
      </tr>
      <tr>
        <td
          style="padding-top:60px;padding-bottom:40px;padding-left:5%;padding-right:5%;text-align: center;font-size: 12px;color: #00569e;">
          <%= disclaimer %>



<%= legalAddress %><br />
          Telephone calls may be recorded.<br />
          <%= contactPhone %>
        </td>
      </tr>
    </table>
  </section>
</body>

</html>
